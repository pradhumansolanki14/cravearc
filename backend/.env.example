# ──────────────────────────────────────────────────────────
# Tomato Food Delivery — Backend Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret

# ── Payments ─────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_replace_with_your_key_id
RAZORPAY_KEY_SECRET=replace_with_your_key_secret
RAZORPAY_WEBHOOK_SECRET=replace_with_your_webhook_secret

# ── Admin registration guard ──────────────────────────────
ADMIN_SECRET_KEY=replace_with_a_strong_secret

# ── Platform Admin initialization (scripts/initPlatformAdmin.js) ──
# Set these before running the script. They are never used at server runtime.
PLATFORM_ADMIN_EMAIL=admin@example.com
PLATFORM_ADMIN_PASSWORD=ChangeMe123!
# Optional — defaults to "Platform Administrator" if not set
# PLATFORM_ADMIN_NAME=Platform Administrator

# ── Cloudinary Media Storage ──────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Email Service (Resend Provider) ────────────────────────
RESEND_API_KEY=your_resend_api_key
FRONTEND_URL=http://localhost:5173
